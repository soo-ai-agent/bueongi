# Kakao Maps JS SDK 앱키 (Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키)
# 설정 시 실제 지도가 켜지고, 미설정/로드 실패 시 RouteMap이 MapMock으로 폴백한다.
VITE_KAKAO_JS_KEY=

# E-1 Tmap 보행자 경로 AppKey (SK open API > Tmap > 앱 키).
# 앱이 Tmap을 직접 호출한다(서버 프록시 금지). 미설정 시 백엔드/목업 경로로 폴백한다.
VITE_TMAP_APP_KEY=

# 정적 안심 데이터 CDN base URL. 자치구별 JSON(cctv/{시군구코드}.json 등)과 manifest.json을 제공한다.
# 예: https://cdn.example.com/bueongi
VITE_CDN_BASE_URL=

# 서울 열린데이터광장 A-1/A-2/A-3 안심귀갓길 Open API 인증키.
# 앱이 첫 실행/월1회 직접 호출 후 로컬 캐시한다. 미설정 시 CDN 기반 점수로만 추천한다.
VITE_SEOUL_OPENAPI_KEY=

# 위치 공유 서버 base URL (POST /share/create, POST/GET /share/{token}/location).
# 미설정 시 '위치 공유'는 정적 링크 복사 폴백으로 동작한다.
VITE_SHARE_API_BASE_URL=
